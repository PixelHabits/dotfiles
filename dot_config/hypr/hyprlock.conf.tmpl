# ~/.config/hypr/hyprlock.conf
# for more configuration options, refer https://wiki.hyprland.org/Hypr-Ecosystem/hyprlock
#
# rendered text in all widgets supports pango markup (e.g. <b> or <i> tags)
# ref. https://wiki.hyprland.org/Hypr-Ecosystem/hyprlock/#general-remarks
#
# shortcuts to clear password buffer: ESC, Ctrl+U, Ctrl+Backspace
#
# you can get started by copying this config to ~/.config/hypr/hyprlock.conf
#

$font = JetBrainsMono Nerd Font

general {
    hide_cursor = true
}

{{ if eq .hostname "GAM-DEV001" -}}
# uncomment to enable fingerprint authentication
auth {
    fingerprint {
        enabled = true
        ready_message = 󰈷 Scan fingerprint or type password to unlock
	present_message = Scanning... 
	retry_delay = 250 # in milliseconds
    }
}
{{- end }}

animations {
    enabled = true
    bezier = linear, 1, 1, 0, 0
    animation = fadeIn, 1, 5, linear
    animation = fadeOut, 1, 5, linear
    animation = inputFieldDots, 1, 2, linear
}

background {
    monitor =
    # Pure black background, zero rendering cost
    color = rgba(0, 0, 0, 1.0)
}

# TIME
label {
    monitor =
    text = $TIME # ref. https://wiki.hyprland.org/Hypr-Ecosystem/hyprlock/#variable-substitution
    font_size = 90
    font_family = $font

    position = 0, 120
    halign = center
    valign = center
}

# DATE
label {
    monitor =
    text = cmd[update:60000] date +"%A, %d %B %Y" # update every 60 seconds
    font_size = 25
    font_family = $font

    position = 0, 20
    halign = center
    valign = center
}

{{ if eq .hostname "GAM-DEV001" -}}
# FINGERPRINT STATUS
label {
    monitor =
    text = $FPRINTPROMPT
    font_size = 13
    font_family = $font
    color = rgb(150, 150, 150)
    
    valign = center
    halign = center
    position = 0, -50
}
{{- end }}

# PASSWORD INPUT FIELD
input-field {
    monitor =
    size = 400, 60
    outline_thickness = 2
    inner_color = rgba(0, 0, 0, 1.0)

    outer_color = rgba(255, 255, 255, 0.1)
    check_color = rgba(255, 255, 255, 0.5)
    fail_color = rgba(255, 0, 0, 0.5)

    font_color = rgb(200, 200, 200)
    {{ if eq .hostname "GAM-DEV001" -}}
    fade_on_empty = true
    {{- else -}}
    fade_on_empty = false
    {{- end }}
    rounding = 8
    font_family = $font
    placeholder_text = Enter Password...
    fail_text = $FAIL

    # uncomment to use a letter instead of a dot to indicate the typed password
    # dots_text_format = *
    # dots_size = 0.4
    dots_spacing = 0.3
    dots_center = true

    # uncomment to use an input indicator that does not show the password length (similar to swaylock's input indicator)
    # hide_input = true

    position = 0, -130
    halign = center
    valign = center
}


