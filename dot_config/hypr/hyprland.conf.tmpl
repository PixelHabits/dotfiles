# See https://wiki.hypr.land/Configuring/Dwindle-Layout/ for more
dwindle {
    pseudotile = true # Master switch for pseudotiling. Enabling is bound to mainMod + P in the keybinds section below
    preserve_split = true # You probably want this
}

# See https://wiki.hypr.land/Configuring/Master-Layout/ for more
master {
    new_status = master
}

# https://wiki.hypr.land/Configuring/Variables/#misc
misc {
    force_default_wallpaper = 0 # Set to 0 or 1 to disable the anime mascot wallpapers
    disable_hyprland_logo = false # If true disables the random hyprland logo / anime girl background. :(
}


#############
### INPUT ###
#############

# https://wiki.hypr.land/Configuring/Variables/#input
input {
    kb_layout = us
    kb_variant =
    kb_model =
    kb_options =
    kb_rules =

    follow_mouse = 1

    sensitivity = 0 # -1.0 - 1.0, 0 means no modification.

    touchpad {
        natural_scroll = false
    }
    numlock_by_default = 1
}

# See https://wiki.hypr.land/Configuring/Gestures
gesture = 3, horizontal, workspace

# Example per-device config
# See https://wiki.hypr.land/Configuring/Keywords/#per-device-input-configs for more
device {
    name = epic-mouse-v1
    sensitivity = -0.5
}


###################
### KEYBINDINGS ###
###################

# See https://wiki.hypr.land/Configuring/Keywords/
$mainMod = SUPER

# Keybind hierarchy:
#   $mainMod          — core operations (clipboard, close, focus, workspaces)
#   $mainMod+SHIFT    — movement, app launchers, secondary actions
#   $mainMod+CTRL     — system controls & panels
#   $mainMod+ALT      — secondary (groups, tmux, etc.)

# --- $mainMod: Core Operations ---

# Clipboard (three-layer bridge: $mainMod -> Ctrl/Shift+Insert -> universal copy/paste)
# Requires Ghostty keybind: ctrl+insert=copy_to_clipboard, shift+insert=paste_from_clipboard
bindd = $mainMod, C, Universal copy, sendshortcut, CTRL, Insert,
bindd = $mainMod, V, Universal paste, sendshortcut, SHIFT, Insert,
bindd = $mainMod, X, Universal cut, sendshortcut, CTRL, X,

# Window management
bindd = $mainMod, W, Close window, killactive,
bindd = $mainMod, F, Fullscreen toggle, fullscreen, 0
bindd = $mainMod ALT, F, Full width, fullscreen, 1
bindd = $mainMod, T, Toggle floating/tiling, togglefloating,
bindd = $mainMod, P, Pseudo (dwindle), pseudo,
bindd = $mainMod, J, Toggle split (dwindle), layoutmsg, togglesplit
bindd = $mainMod, A, Pin window, pin,
bindd = $mainMod, O, Pop window out (float & pin), exec, omarchy-hyprland-window-pop
bindd = $mainMod, S, Toggle workspace layout, exec, omarchy-hyprland-workspace-layout-toggle
# bind = $mainMod, M, exec, command -v hyprshutdown >/dev/null 2>&1 && hyprshutdown || hyprctl dispatch exit

# Applications
bindd = $mainMod, RETURN, Terminal (tmux), exec, uwsm app -- $terminal -e zsh -c 'tmux attach || tmux new -s main'
bindd = $mainMod ALT, RETURN, Terminal, exec, uwsm app -- $terminal
bindd = $mainMod, SPACE, App launcher, exec, uwsm app -- $menu
bindd = $mainMod SHIFT, B, Browser, exec, uwsm app -- $browser
bindd = $mainMod SHIFT, F, File manager, exec, uwsm app -- $fileManager
bindd = $mainMod SHIFT, N, Editor, exec, uwsm app -- $terminal -e nvim
bindd = $mainMod SHIFT, M, Music, exec, xdg-open https://music.youtube.com
bindd = $mainMod SHIFT, SLASH, Passwords, exec, uwsm app -- 1password
bindd = $mainMod, L, Lock session, exec, loginctl lock-session

# Notifications (mako)
bindd = $mainMod, COMMA, Dismiss last notification, exec, makoctl dismiss
bindd = $mainMod SHIFT, COMMA, Dismiss all notifications, exec, makoctl dismiss --all
bindd = $mainMod ALT, COMMA, Restore last notification, exec, makoctl restore

# Focus
bindd = $mainMod, left, Focus left, movefocus, l
bindd = $mainMod, right, Focus right, movefocus, r
bindd = $mainMod, up, Focus up, movefocus, u
bindd = $mainMod, down, Focus down, movefocus, d

# Workspaces
bind = $mainMod, 1, workspace, 1
bind = $mainMod, 2, workspace, 2
bind = $mainMod, 3, workspace, 3
bind = $mainMod, 4, workspace, 4
bind = $mainMod, 5, workspace, 5
bind = $mainMod, 6, workspace, 6
bind = $mainMod, 7, workspace, 7
bind = $mainMod, 8, workspace, 8
bind = $mainMod, 9, workspace, 9
bind = $mainMod, 0, workspace, 10
bindd = $mainMod, TAB, Next workspace, workspace, e+1
bind = $mainMod, grave, togglespecialworkspace, scratchpad

# Resize (horizontal)
bindd = $mainMod, minus, Shrink window width, resizeactive, -100 0
bindd = $mainMod, equal, Grow window width, resizeactive, 100 0

# Mouse
bind = $mainMod, mouse_down, workspace, e+1
bind = $mainMod, mouse_up, workspace, e-1
bindm = $mainMod, mouse:272, movewindow
bindm = $mainMod, mouse:273, resizewindow

# --- $mainMod+SHIFT: Movement & App Launchers ---

# Swap windows
bindd = $mainMod SHIFT, left, Swap window left, swapwindow, l
bindd = $mainMod SHIFT, right, Swap window right, swapwindow, r
bindd = $mainMod SHIFT, up, Swap window up, swapwindow, u
bindd = $mainMod SHIFT, down, Swap window down, swapwindow, d

# Move window to workspace
bind = $mainMod SHIFT, 1, movetoworkspace, 1
bind = $mainMod SHIFT, 2, movetoworkspace, 2
bind = $mainMod SHIFT, 3, movetoworkspace, 3
bind = $mainMod SHIFT, 4, movetoworkspace, 4
bind = $mainMod SHIFT, 5, movetoworkspace, 5
bind = $mainMod SHIFT, 6, movetoworkspace, 6
bind = $mainMod SHIFT, 7, movetoworkspace, 7
bind = $mainMod SHIFT, 8, movetoworkspace, 8
bind = $mainMod SHIFT, 9, movetoworkspace, 9
bind = $mainMod SHIFT, 0, movetoworkspace, 10
bindd = $mainMod SHIFT, TAB, Previous workspace, workspace, e-1
bind = $mainMod SHIFT, grave, movetoworkspacesilent, special:scratchpad

# Resize (vertical)
bindd = $mainMod SHIFT, minus, Shrink window height, resizeactive, 0 -100
bindd = $mainMod SHIFT, equal, Grow window height, resizeactive, 0 100

# Screenshots (Hyprshot)
bindd = $mainMod, PRINT, Screenshot window, exec, hyprshot -m window -z
bindd = $mainMod SHIFT, S, Screenshot region, exec, hyprshot -m region -z
bindd = , PRINT, Screenshot monitor, exec, hyprshot -m output -m active
bindd = $mainMod ALT, PRINT, Color picker, exec, pkill hyprpicker || hyprpicker -a

# Aesthetics
bindd = $mainMod SHIFT, SPACE, Toggle top bar, exec, omarchy-toggle-waybar

# --- $mainMod+CTRL: System Controls ---

bindd = $mainMod CTRL, N, Toggle night light, exec, omarchy-toggle-nightlight
bindd = $mainMod CTRL, T, Activity, exec, uwsm app -- $terminal -e btop

# --- $mainMod+SHIFT+ALT: Tertiary ---

# Move window silently to workspace (window goes, view stays)
bind = $mainMod SHIFT ALT, 1, movetoworkspacesilent, 1
bind = $mainMod SHIFT ALT, 2, movetoworkspacesilent, 2
bind = $mainMod SHIFT ALT, 3, movetoworkspacesilent, 3
bind = $mainMod SHIFT ALT, 4, movetoworkspacesilent, 4
bind = $mainMod SHIFT ALT, 5, movetoworkspacesilent, 5
bind = $mainMod SHIFT ALT, 6, movetoworkspacesilent, 6
bind = $mainMod SHIFT ALT, 7, movetoworkspacesilent, 7
bind = $mainMod SHIFT ALT, 8, movetoworkspacesilent, 8
bind = $mainMod SHIFT ALT, 9, movetoworkspacesilent, 9
bind = $mainMod SHIFT ALT, 0, movetoworkspacesilent, 10

# Move workspace to another monitor
bindd = $mainMod SHIFT ALT, left, Move workspace to left monitor, movecurrentworkspacetomonitor, l
bindd = $mainMod SHIFT ALT, right, Move workspace to right monitor, movecurrentworkspacetomonitor, r
bindd = $mainMod SHIFT ALT, up, Move workspace to upper monitor, movecurrentworkspacetomonitor, u
bindd = $mainMod SHIFT ALT, down, Move workspace to lower monitor, movecurrentworkspacetomonitor, d

# --- Non-modifier ---

bindd = CTRL ALT, DELETE, Close all windows, exec, omarchy-hyprland-window-close-all
bindld = , XF86PowerOff, Lock session, exec, loginctl lock-session

# --- Hardware / Media Keys ---

# Volume and brightness
bindel = ,XF86AudioRaiseVolume, exec, wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%+
bindel = ,XF86AudioLowerVolume, exec, wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindel = ,XF86AudioMute, exec, wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindel = ,XF86AudioMicMute, exec, wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle
bindel = ,XF86MonBrightnessUp, exec, brightnessctl -e4 -n2 set 5%+
bindel = ,XF86MonBrightnessDown, exec, brightnessctl -e4 -n2 set 5%-

# Precise 1% adjustments with Alt modifier
bindel = ALT, XF86AudioRaiseVolume, exec, wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 1%+
bindel = ALT, XF86AudioLowerVolume, exec, wpctl set-volume @DEFAULT_AUDIO_SINK@ 1%-
bindel = ALT, XF86MonBrightnessUp, exec, brightnessctl -e4 -n2 set 1%+
bindel = ALT, XF86MonBrightnessDown, exec, brightnessctl -e4 -n2 set 1%-

# Keyboard backlight
bindel = ,XF86KbdBrightnessUp, exec, brightnessctl -d '*::kbd_backlight' set 1+
bindel = ,XF86KbdBrightnessDown, exec, brightnessctl -d '*::kbd_backlight' set 1-

# Media controls (requires playerctl)
bindl = , XF86AudioNext, exec, playerctl next
bindl = , XF86AudioPause, exec, playerctl play-pause
bindl = , XF86AudioPlay, exec, playerctl play-pause
bindl = , XF86AudioPrev, exec, playerctl previous

##############################
### WINDOWS AND WORKSPACES ###
##############################

# See https://wiki.hypr.land/Configuring/Window-Rules/ for more
# See https://wiki.hypr.land/Configuring/Workspace-Rules/ for workspace rules

# Example windowrules that are useful

layerrule = no_anim on, match:namespace selection

windowrule {
    # Ignore maximize requests from all apps. You'll probably like this.
    name = suppress-maximize-events
    match:class = .*

    suppress_event = maximize
}

windowrule {
    # Fix some dragging issues with XWayland
    name = fix-xwayland-drags
    match:class = ^$
    match:title = ^$
    match:xwayland = true
    match:float = true
    match:fullscreen = false
    match:pin = false

    no_focus = true
}

# Hyprland-run windowrule
windowrule {
    name = move-hyprland-run

    match:class = hyprland-run

    move = 20 monitor_h-120
    float = yes
}
