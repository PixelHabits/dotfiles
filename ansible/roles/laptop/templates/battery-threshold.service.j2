[Unit]
Description=Set {{ battery_device }} charging threshold to 80 percent
ConditionPathExists=/sys/class/power_supply/{{ battery_device }}/charge_control_end_threshold

[Service]
Type=oneshot
ExecStart=/usr/bin/sh -c 'printf "80\n" > /sys/class/power_supply/{{ battery_device }}/charge_control_end_threshold'

[Install]
WantedBy=multi-user.target
