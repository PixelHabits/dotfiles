[Unit]
Description=Set BAT0 charging threshold to 80 percent
ConditionPathExists=/sys/class/power_supply/BAT0/charge_control_end_threshold
After=multi-user.target suspend.target hibernate.target hybrid-sleep.target suspend-then-hibernate.target

[Service]
Type=oneshot
ExecStart=/usr/bin/sh -c 'printf "80\n" > /sys/class/power_supply/BAT0/charge_control_end_threshold'

[Install]
WantedBy=multi-user.target suspend.target hibernate.target hybrid-sleep.target suspend-then-hibernate.target
